# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# Cloudinary (storage de imagens)
VITE_CLOUDINARY_CLOUD_NAME=""
VITE_CLOUDINARY_UPLOAD_PRESET=""

# YouTube Data API v3 — usado pelo serverless /api/youtube/live (NUNCA expor ao cliente)
# Crie em https://console.cloud.google.com/apis/credentials
# Restrinja por IP do servidor da Vercel ou por API (apenas YouTube Data API v3).
YOUTUBE_API_KEY=""
YOUTUBE_CHANNEL_ID=""

# Instagram Graph API (Meta) — usado pelo serverless /api/instagram/insights (NUNCA expor ao cliente)
# Requer conta IG Business/Creator vinculada a uma Página do Facebook + app na Meta.
# INSTAGRAM_ACCESS_TOKEN: token de LONGA duração (~60 dias — precisa ser renovado).
# INSTAGRAM_BUSINESS_ACCOUNT_ID: ID numérico da conta IG Business (obtido via Página do FB).
# Passo a passo em https://developers.facebook.com/docs/instagram-api/getting-started
INSTAGRAM_ACCESS_TOKEN=""
INSTAGRAM_BUSINESS_ACCOUNT_ID=""
